# Copy this file to .env and adjust values for your local environment.
# .env is gitignored — never commit real secrets.
#
# All variables here are CONSUMED by docker-compose.yml and/or the Python
# entry points (kafka_publisher, run_consumer, api). Defaults are sensible
# for a local Docker Desktop run.

# ----------------------------------------------------------------------------
# Redpanda (Kafka-compatible broker)
# ----------------------------------------------------------------------------
# Internal listener used by services inside the docker network (dsnet).
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
# External listener (mapped to host port). Use this for host-side debugging,
# e.g. running rpk / a Python script from your laptop.
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:19092
KAFKA_TOPIC=uxsim

# ----------------------------------------------------------------------------
# UXSIM producer
# ----------------------------------------------------------------------------
# Wall-clock pause between simulation steps when streaming records.
PRODUCE_INTERVAL_SEC=1
# Total simulated time (seconds). The default UXSIM scenario runs for 3600s.
SIMULATION_TMAX=3600
# Optional integer seed for reproducible runs. Empty = random.
SIMULATION_SEED=

# ----------------------------------------------------------------------------
# MongoDB
# ----------------------------------------------------------------------------
# Internal URI (used by Spark and the API container).
MONGO_URI=mongodb://mongo:27017
# Host URI (used by mongosh on the laptop or by scripts/verify_pipeline.py).
MONGO_URI_HOST=mongodb://localhost:27017
MONGO_DATABASE=traffic
MONGO_RAW_COLLECTION=raw_data
MONGO_STATS_COLLECTION=stats
MONGO_WINDOWED_COLLECTION=stats_windowed

# ----------------------------------------------------------------------------
# Spark
# ----------------------------------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_APP_NAME=UXSIM-Consumer
# Set to 1 to also write the stats stream to console (verbose; debugging only).
SPARK_DEBUG_CONSOLE=0

# ----------------------------------------------------------------------------
# REST API (bonus profile)
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
