# Reduce the build context sent to the Docker daemon.
# Anything matched here is NOT shipped to images, regardless of COPY rules.

# VCS
.git/
.gitignore
.gitattributes

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Test / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp

# Local secrets and docs (we re-copy what we need explicitly)
.env
.env.local
*.md
docs/
notebooks/
tests/

# Spark / UXSIM local outputs
metastore_db/
spark-warehouse/
out/
checkpoints/
*.gif
*.log

# OS
.DS_Store
Thumbs.db
